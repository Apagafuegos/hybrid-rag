# Hybrid RAG — Environment Configuration (Retail Edition)
# Copy this file to .env and fill in your actual values.

# ---------------------------------------------------------------------------
# Retail data sources (absolute paths)
# ---------------------------------------------------------------------------
RETAIL_ARTICLES_CSV=/home/ubuntu/raw_data/d_articulos.csv
RETAIL_CATEGORIES_CSV=/home/ubuntu/raw_data/d_categorizacion_tbl.csv
# Activity filter: only process rows where uid == this value
RETAIL_ACTIVITY_FILTER=FOOD

# ---------------------------------------------------------------------------
# OpenRouter API (OpenAI-compatible)
# ---------------------------------------------------------------------------
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# Default embedding provider: "openrouter" or "fastembed"
DENSE_EMBED_PROVIDER=openrouter

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agnostic_rag_collection

# ---------------------------------------------------------------------------
# MCP Server Authentication
# ---------------------------------------------------------------------------
# Set a strong random string. Clients must send:
#   Authorization: Bearer <base64(MCP_API_KEY)>
# If left empty, auth is disabled (NOT recommended for production).
MCP_API_KEY=your-secret-api-key-here

# ---------------------------------------------------------------------------
# Ingestion tuning
# ---------------------------------------------------------------------------
INGEST_BATCH_SIZE=64
# Delay between batches (seconds) — helps avoid rate limits on OpenRouter
INTER_BATCH_DELAY=0.2
# Checkpoint file for resume support
INGEST_CHECKPOINT_FILE=.ingest_checkpoint.json
# Set to true to clear checkpoint and start from scratch
FRESH_START=false
# Dense vector dimension (1536 for text-embedding-3-small)
DENSE_VECTOR_DIM=1536
